<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Questrial&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}

  <style>
    :root {
      --rose:   {{ settings.color_rose }};
      --vieux:  {{ settings.color_vieux }};
      --poudre: {{ settings.color_poudre }};
      --vert:   {{ settings.color_vert }};
      --blanc:  {{ settings.color_blanc }};
      --marron: {{ settings.color_marron }};
    }
  </style>
</head>
<body class="template-password">
  {{ content_for_layout }}
</body>
</html>
