{%- comment -%} ═══ RÉINITIALISATION MOT DE PASSE ═══ {%- endcomment -%}

<div class="account-page">
  <div class="account-card">
    <h1 class="account-title">{{ 'customer.reset_password' | t }}</h1>
    <p class="account-desc">{{ 'customer.reset_password_message' | t }}</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="form-error">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="form-field">
        <label class="form-label" for="reset-pw">{{ 'customer.new_password' | t }}</label>
        <input class="form-input" type="password" id="reset-pw" name="customer[password]"
          autocomplete="new-password" required>
      </div>

      <div class="form-field">
        <label class="form-label" for="reset-pw-confirm">{{ 'customer.confirm_password' | t }}</label>
        <input class="form-input" type="password" id="reset-pw-confirm"
          name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>

      <button type="submit" class="form-btn">{{ 'customer.reset_button' | t }}</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Réinitialisation mot de passe",
  "class": "section-customer-reset",
  "settings": []
}
{% endschema %}
