    },
    {
      "type": "textarea",
      "id": "b2b_desc",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "b2b_cta",
      "label": "Texte bouton",
      "default": "Faire une demande"
    },
    {
      "type": "url",
      "id": "b2b_url",
      "label": "Lien"
    }
  ],
  "presets": [
    {
      "name": "Split B2C / B2B"
    }
  ]
