{%- comment -%} ═══ SPLIT B2C / B2B ═══ {%- endcomment -%}
<div class="split reveal">
  <div class="split-divider"></div>

  <div class="split-center-label">
    <div class="scl-inner">ou</div>
  </div>

  {%- comment -%} Panel B2C {%- endcomment -%}
  <div class="panel panel-b2c">
    <div class="panel-photo" style="background-image:url('{% if section.settings.b2c_image %}{{ section.settings.b2c_image | image_url: width: 1200 }}{% else %}{{ 'panel-b2c.jpg' | asset_url }}{% endif %}')"></div>
    <div class="panel-overlay"></div>

    <span class="panel-tag">{{ section.settings.b2c_tag | default: 'Particuliers' }}</span>

    <div class="panel-logo">
      {%- render 'svg-logo', width: 140, height: 80, color: 'rgba(240,240,230,.15)', id: 'panel-b2c' -%}
    </div>

    <span class="panel-num">01</span>

    <div class="panel-content">
      <span class="panel-eyebrow">{{ section.settings.b2c_eyebrow | default: 'Boutique en ligne' }}</span>
      <h2 class="panel-title">{{ section.settings.b2c_title | default: 'Pour vous,<br><em>pour offrir.</em>' }}</h2>
      <p class="panel-desc">{{ section.settings.b2c_desc | default: "Commandez nos créations du moment — livrées fraîches, façonnées le matin même. Idéal pour un dîner, une attention, ou simplement se faire plaisir." }}</p>
      <div class="panel-services">
        <span class="svc-tag">Click & collect</span>
        <span class="svc-tag">Livraison Paris</span>
        <span class="svc-tag">Coffrets cadeaux</span>
      </div>
      <a href="{{ section.settings.b2c_url | default: '/collections' }}" class="panel-cta">
        {{ section.settings.b2c_cta | default: 'Commander' }}
        <span class="cta-arrow">→</span>
      </a>
    </div>
  </div>

  {%- comment -%} Panel B2B {%- endcomment -%}
  <div class="panel panel-b2b">
    <div class="panel-photo" style="background-image:url('{% if section.settings.b2b_image %}{{ section.settings.b2b_image | image_url: width: 1200 }}{% else %}{{ 'panel-b2b.jpg' | asset_url }}{% endif %}')"></div>
    <div class="panel-overlay"></div>

    <span class="panel-tag">{{ section.settings.b2b_tag | default: 'Professionnels' }}</span>

    <div class="panel-logo">
      {%- render 'svg-logo', width: 140, height: 80, color: 'rgba(240,240,230,.15)', id: 'panel-b2b' -%}
    </div>

    <span class="panel-num">02</span>

    <div class="panel-content">
      <span class="panel-eyebrow">{{ section.settings.b2b_eyebrow | default: 'Maison Félicien Pro' }}</span>
      <h2 class="panel-title">{{ section.settings.b2b_title | default: 'Pour vos<br><em>événements.</em>' }}</h2>
      <p class="panel-desc">{{ section.settings.b2b_desc | default: "Mariages, séminaires, cocktails d'entreprise, cadeaux clients. Un interlocuteur dédié, des créations sur-mesure, une présentation à la hauteur de vos exigences." }}</p>
      <div class="panel-services">
        <span class="svc-tag">Mariages & réceptions</span>
        <span class="svc-tag">Entreprises</span>
        <span class="svc-tag">Sur-mesure</span>
        <span class="svc-tag">Grand volume</span>
      </div>
      <a href="{{ section.settings.b2b_url | default: 'https://pro.maison-felicien.com' }}" class="panel-cta">
        {{ section.settings.b2b_cta | default: 'Faire une demande' }}
        <span class="cta-arrow">→</span>
      </a>
    </div>
  </div>
</div>

{%- comment -%} Bridge band {%- endcomment -%}
<div class="bridge reveal">
  <span class="bridge-item">
    <span class="bridge-dot"></span>
    Paris & Île-de-France
  </span>
  <span class="bridge-sep"></span>
  <span class="bridge-item">
    <span class="bridge-dot"></span>
    Commande 48h à l'avance
  </span>
  <span class="bridge-sep"></span>
  <span class="bridge-item">
    <span class="bridge-dot"></span>
    Devis pro sous 24h
  </span>
  <span class="bridge-sep"></span>
  <span class="bridge-item">
    <span class="bridge-dot"></span>
    Recettes de saison
  </span>
</div>

