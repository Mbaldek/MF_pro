{%- comment -%} ═══ HERO HOMEPAGE ═══ {%- endcomment -%}
<section class="hero">
  <div class="hero-photo"
    style="background-image:url('{% if section.settings.hero_image %}{{ section.settings.hero_image | image_url: width: 2000 }}{% else %}{{ 'hero-bg.jpg' | asset_url }}{% endif %}')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-vignette"></div>

  <div class="hero-topleft">
    <p class="hero-eyebrow hero-entrance">{{ section.settings.eyebrow | default: 'Pâtisserie artisanale · Paris' }}</p>
    <h1 class="hero-headline hero-entrance">{{ section.settings.headline | default: 'Quand la nature<br>devient <em>gourmandise.</em>' }}</h1>
    <p class="hero-desc hero-entrance">{{ section.settings.description | default: 'Pâtisseries façonnées chaque jour en atelier, livrées fraîches partout en France. Produits de saison, recettes artisanales, ingrédients nobles.' }}</p>
    <a href="{{ section.settings.cta_url | default: '/collections' }}" class="hero-cta hero-entrance">
      <span class="cta-dot"></span>
      {{ section.settings.cta_text | default: 'Découvrir nos créations' }}
      <span class="cta-arrow">→</span>
    </a>
  </div>

  <div class="hero-brand hero-entrance">
    {%- render 'svg-logo-full', width: 320, height: 181, color: 'rgba(240,240,230,.18)', id: 'hero-brand' -%}
  </div>

  <div class="hero-bottombar">
    <div class="hbb-col">
      <span class="hbb-label">Atelier Paris</span>
      <span class="hbb-val">Façonné chaque jour</span>
    </div>
    <div class="hbb-scroll">
      <div class="hbb-line"></div>
      <span class="hbb-scrolltext">Scroll</span>
    </div>
    <div class="hbb-col right">
      <span class="hbb-label">Saison</span>
      <span class="hbb-val">Printemps 2026</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Pâtisserie artisanale · Paris"
    },
    {
      "type": "html",
      "id": "headline",
      "label": "Titre principal",
      "default": "Quand la nature<br>devient <em>gourmandise.</em>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Pâtisseries façonnées chaque jour en atelier, livrées fraîches partout en France. Produits de saison, recettes artisanales, ingrédients nobles."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Découvrir nos créations"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton",
      "default": "/collections"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
