    {
      "type": "text",
      "id": "start_cta",
      "label": "Bouton commencer",
      "default": "Commencer →"
    },
    {
      "type": "text",
      "id": "q1",
      "label": "Question 1",
      "default": "Vous êtes plutôt…"
    },
    {
      "type": "text",
      "id": "q2",
      "label": "Question 2",
      "default": "C'est pour…"
    },
    {
      "type": "text",
      "id": "q3",
      "label": "Question 3",
      "default": "Votre email pour découvrir vos recommandations"
    },
    {
      "type": "text",
      "id": "email_cta",
      "label": "Bouton email",
      "default": "Découvrir →"
    },
    {
      "type": "text",
