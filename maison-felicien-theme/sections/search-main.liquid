{%- comment -%} ═══ PAGE RECHERCHE ═══ {%- endcomment -%}

<div class="search-page">
  <h1 class="search-title">{{ 'search.title' | t }}</h1>

  <form action="/search" method="get" class="search-form">
    <input type="search" name="q" class="search-input"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      autocomplete="off" autocorrect="off" autocapitalize="off">
    <button type="submit" class="search-btn">{{ 'search.search_button' | t }}</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p class="search-count">
        {{ 'search.results_count' | t: count: search.results_count, terms: search.terms }}
      </p>

      <div class="products-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- else -%}
            <a href="{{ item.url }}" class="search-result-page">
              <h3 class="search-result-title">{{ item.title }}</h3>
              <p class="search-result-excerpt">{{ item.content | strip_html | truncatewords: 20 }}</p>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if search.results.size < search.results_count -%}
        <div class="search-pagination">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="search-empty">
        <p class="search-empty-msg">{{ 'search.no_results' | t: terms: search.terms }}</p>
        <p class="search-empty-hint">{{ 'search.no_results_message' | t }}</p>
        <a href="/collections" class="search-empty-cta">{{ 'general.view_all' | t }}</a>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Recherche",
  "class": "section-search",
  "settings": []
}
{% endschema %}
