{%- comment -%} ═══ PANIER ═══ {%- endcomment -%}

<div class="cart-page">
  <h1 class="cart-title reveal">Votre <em>panier</em></h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-empty reveal d1">
      <p class="cart-empty-msg">Votre panier est vide.</p>
      <a href="/collections" class="cart-empty-cta">Découvrir nos créations →</a>
    </div>
  {%- else -%}
    <div class="cart-layout reveal d1">
      <div class="cart-items">
        {%- for item in cart.items -%}
          <div class="cart-item" data-line="{{ forloop.index }}">
            <div class="ci-img">
              {%- if item.image -%}
                <div class="ci-photo" style="background-image:url('{{ item.image | image_url: width: 200 }}')"></div>
              {%- endif -%}
            </div>
            <div class="ci-details">
              <a href="{{ item.url }}" class="ci-name">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}
                <span class="ci-variant">{{ item.variant.title }}</span>
              {%- endif -%}
              <span class="ci-price">{{ item.price | money }}</span>
            </div>
            <div class="ci-qty">
              <button class="qty-btn" onclick="MF.cartQty({{ forloop.index }}, {{ item.quantity | minus: 1 }})">−</button>
              <span class="qty-num">{{ item.quantity }}</span>
              <button class="qty-btn" onclick="MF.cartQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})">+</button>
            </div>
            <div class="ci-total">{{ item.line_price | money }}</div>
            <button class="ci-remove" onclick="MF.cartQty({{ forloop.index }}, 0)">×</button>
          </div>
        {%- endfor -%}
      </div>

      <div class="cart-summary">
        <div class="cs-row">
          <span>Sous-total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cs-row cs-note">
          <span>Livraison calculée au checkout</span>
        </div>
        <a href="/checkout" class="cart-checkout-btn">
          Passer commande <span class="arrow">→</span>
        </a>
        <a href="/collections" class="cart-continue">← Continuer mes achats</a>
      </div>
    </div>
  {%- endif -%}
</div>

<script>
  MF.cartQty = function(line, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty })
    })
    .then(function() { window.location.reload(); });
  };
</script>

{% schema %}
{
  "name": "Panier",
  "class": "section-cart",
  "settings": [],
  "presets": [
    {
      "name": "Panier"
    }
  ]
}
{% endschema %}
