{%- comment -%} ═══ PASSWORD PAGE — Store verrouillé ═══ {%- endcomment -%}

<div class="password-page">
  <div class="password-card">
    {% render 'svg-logo', width: 80, height: 80, color: 'var(--blanc)' %}

    <h1 class="password-title">{{ shop.name }}</h1>
    <p class="password-subtitle">{{ 'password_page.title' | t }}</p>
    <p class="password-desc">{{ 'password_page.subtitle' | t }}</p>

    {%- form 'storefront_password' -%}
      <div class="password-form">
        <input type="password" name="password" class="password-input"
          placeholder="{{ 'password_page.placeholder' | t }}" autocomplete="current-password">
        <button type="submit" class="password-btn">{{ 'password_page.enter' | t }}</button>
      </div>
      {%- if form.errors -%}
        <p class="password-error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}

    <p class="password-powered">{{ 'password_page.powered_by' | t }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "class": "section-password",
  "settings": []
}
{% endschema %}
