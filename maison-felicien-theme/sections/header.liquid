{%- comment -%}
  Navigation unifiée — burger menu + CTA Commander
  Homepage : transparente → compacte au scroll
  Autres pages : compacte d'office (fond blanc)
{%- endcomment -%}

<nav id="nav"{% unless template.name == 'index' %} class="compact"{% endunless %}>
  {%- comment -%} Logo gauche {%- endcomment -%}
  <a class="nav-logo-link" href="/">
    <span class="nav-logo-hero">
      {%- render 'svg-logo', width: 38, height: 39, color: '#F0F0E6', id: 'nav-hero' -%}
    </span>
    <span class="nav-logo-compact">
      {%- render 'svg-logo', width: 32, height: 33, color: '#8B3A43', id: 'nav-compact' -%}
    </span>
  </a>

  {%- comment -%} Droite : burger + commander {%- endcomment -%}
  <div class="nav-right">
    <div class="nav-burger-wrap">
      <button class="nav-burger" aria-label="Menu" aria-expanded="false">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
      <div class="nav-dropdown">
        <a href="/" class="nav-dd-link{% if template.name == 'index' %} active{% endif %}">Accueil</a>
        <a href="/collections" class="nav-dd-link{% if template.name == 'collection' or template.name == 'list-collections' %} active{% endif %}">Boutique</a>
        <a href="{{ pages['la-maison'].url | default: '/pages/la-maison' }}" class="nav-dd-link{% if page.handle == 'la-maison' %} active{% endif %}">La Maison</a>
        <a href="https://pro.maison-felicien.com" class="nav-dd-link" target="_blank" rel="noopener">Espace Pro</a>
        <div class="nav-dd-sep"></div>
        <a href="/cart" class="nav-dd-link nav-dd-cart" onclick="event.preventDefault(); MF.openCartDrawer();">
          Panier <span class="cart-pill" id="cartCount">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
    <a href="{{ collections.all.url | default: '/collections' }}" class="nav-btn">Commander</a>
  </div>
</nav>

{%- if template.name == 'index' -%}
<script>
(function(){
  var nav = document.getElementById('nav');
  if (!nav) return;
  window.addEventListener('scroll', function() {
    if (window.scrollY > 80) {
      nav.classList.add('compact');
    } else {
      nav.classList.remove('compact');
    }
  }, {passive: true});
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "En-tête",
  "class": "section-header",
  "settings": []
}
{% endschema %}
